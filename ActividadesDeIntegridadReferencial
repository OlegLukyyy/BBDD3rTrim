```
```mysql
INSERT INTO pagos(id, idPedido, cantidad, fecha) 
VALUES (30001,20000,120,"2025-04-01");
-- Cannot add or update a child row: a foreign key constraint fails (`nexus`.`pagos`, CONSTRAINT `fk_pag_ped` FOREIGN KEY (`idPedido`) REFERENCES `pedidos` (`id`))
